DATABASE_URL="postgresql://user:password@localhost:5432/clover_cms"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3000
NODE_ENV=development
BASE_URL="http://localhost:3000"

# Zoho SMTP
ZOHO_EMAIL="you@yourdomain.com"
ZOHO_PASSWORD="your-zoho-app-password"
ZOHO_FROM_NAME="Clover Agency"

# Admin email — receives deliverable review + revision request notifications
ADMIN_EMAIL="admin@yourdomain.com"

# Vercel deploy hook — triggered when a CMS page is published (optional)
VERCEL_DEPLOY_HOOK_URL=""
